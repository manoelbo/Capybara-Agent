{
  "name": "reverso-agent-tmp",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "lab:pdf": "node lab/document-processing-tool/run.js",
    "lab:pdf:sample": "node lab/document-processing-tool/run.js --input \"examples/input/2022_COMBATE_EROSÃO_Jd. Novo Parelheiros.pdf\" --output \"examples/output\" --model \"google/gemini-2.5-flash-lite-preview-09-2025\"",
    "lab:pdf:smoke": "node lab/document-processing-tool/run.js --input \"examples/input/2022_COMBATE_EROSÃO_Jd. Novo Parelheiros.pdf\" --output \"examples/output\" --model \"google/gemini-2.5-flash-lite-preview-09-2025\" --max-pages 2",
    "lab:pdf:ocr": "node lab/document-processing-tool/run.js --input \"examples/input/2022_COMBATE_EROSÃO_Jd. Novo Parelheiros.pdf\" --output \"examples/output\" --chunk-pages 5 --concurrency 15",
    "lab:pdf:ocr:smoke": "node lab/document-processing-tool/run.js --input \"examples/input/2022_COMBATE_EROSÃO_Jd. Novo Parelheiros.pdf\" --output \"examples/output\" --max-pages 2 --chunk-pages 5",
    "lab:pdf:ocr:fast": "node lab/document-processing-tool/run.js --input \"examples/input/2022_COMBATE_EROSÃO_Jd. Novo Parelheiros.pdf\" --output \"examples/output\" --chunk-pages 5 --concurrency 15 --provider-sort latency",
    "lab:source:process-all": "node lab/document-processing-tool/run.js process-all --source lab/source",
    "lab:source:process-selected": "node lab/document-processing-tool/run.js process-selected --source lab/source",
    "lab:source:process-queue": "node lab/document-processing-tool/run.js process-queue --source lab/source",
    "lab:source:queue-status": "node lab/document-processing-tool/run.js queue-status --source lab/source",
    "lab:source:queue-clear": "node lab/document-processing-tool/run.js queue-clear --source lab/source",
    "lab:source:watch": "node lab/document-processing-tool/run.js watch --source lab/source",
    "test:doc-tool": "node --import tsx --test lab/document-processing-tool/tests/source-queue.test.ts lab/document-processing-tool/tests/e2e-smoke.test.ts",
    "test": "pnpm run test:doc-tool"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@ibm/plex-mono": "^1.1.0",
    "@ibm/plex-sans-jp": "^3.0.0",
    "@ibm/plex-sans-thai-looped": "^1.1.0",
    "@napi-rs/canvas": "^0.1.96",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.3.9",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@swc/core": "^1.15.18",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
